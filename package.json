{
  "name": "next-modular-arch",
  "version": "0.1.0",
  "private": true,
  "pnpm": {
    "packageExtensions": {
      "postcss@*": {
        "dependencies": {
          "nanoid": "3.3.7"
        }
      }
    }
  },
  "scripts": {
    "dev": "pnpm dev:stack",
    "dev:stack": "concurrently -k -n home,jp,pk,rm -c blue,green,yellow,magenta \"pnpm --filter @next-modular-arch/home dev\" \"pnpm --filter @next-modular-arch/jsonplaceholder dev\" \"pnpm --filter @next-modular-arch/pokemon dev\" \"pnpm --filter @next-modular-arch/rick-and-morty dev\"",
    "dev:home": "pnpm --filter @next-modular-arch/home dev",
    "build": "pnpm -r --filter \"./apps/**\" run build",
    "lint": "eslint",
    "postinstall": "playwright install chromium",
    "test:e2e:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:local": "env -u CI playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ci": "CI=true playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.2.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "typescript": "^5"
  }
}
